# Backend API (must match CORS; default Express serves /api)
VITE_API_URL=http://localhost:5000/api

# Google OAuth — Web client ID only (OAuth 2.0 "Web application" in Google Cloud Console).
# Do NOT add client secret to the Frontend; keep it in backend/.env only.
VITE_GOOGLE_CLIENT_ID=
#
# Fix Error 400: origin_mismatch — in Google Cloud Console → APIs & Services →
# Credentials → your Web client → "Authorized JavaScript origins", add the EXACT
# origin you use in the browser (scheme + host + port, no path):
#   http://localhost:3000
#   http://127.0.0.1:3000
# (Vite is set to port 3000 in vite.config.ts; if you change the port, add that origin.)
# For production, add: https://your-domain.com
# Save, wait 1–5 minutes, then try again. localhost vs 127.0.0.1 are different origins.

# Android APK download URL (default: /app/student.apk served from public/)
# Set to an absolute URL if you host the APK elsewhere
VITE_ANDROID_APK_URL=/app/student.apk
